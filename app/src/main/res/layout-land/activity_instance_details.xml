<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:background="?android:colorBackground"
    android:paddingTop="8.0dip"
    android:paddingBottom="8.0dip"
    android:clipToPadding="false"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:paddingStart="14.0dip"
    android:paddingEnd="14.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.google.android.material.card.MaterialCardView
        android:id="@id/cardInstanceHeader"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20.0dip"
        app:cardUseCompatPadding="true">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10.0dip"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <com.google.android.material.button.MaterialButton
                android:id="@id/buttonBackFromInstanceDetails"
                android:padding="0.0dip"
                android:layout_width="46.0dip"
                android:layout_height="46.0dip"
                android:minWidth="46.0dip"
                android:minHeight="46.0dip"
                android:contentDescription="@android:string/cancel"
                app:icon="@drawable/ic_arrow_back_24"
                app:iconGravity="textStart"
                app:iconPadding="0.0dip"
                style="@style/Widget.Material3.Button.TextButton.Icon" />
            <ImageView
                android:id="@id/imageInstanceIcon"
                android:background="@drawable/bg_instance_icon"
                android:padding="7.0dip"
                android:layout_width="56.0dip"
                android:layout_height="56.0dip"
                android:src="@mipmap/ic_launcher"
                android:scaleType="centerInside"
                android:contentDescription="@string/create_instance_select_icon"
                android:layout_marginStart="8.0dip" />
            <LinearLayout
