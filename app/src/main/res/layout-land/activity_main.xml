<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:id="@id/mainContent"
    android:background="?android:colorBackground"
    android:padding="12.0dip"
    android:clipToPadding="false"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.google.android.material.card.MaterialCardView
        android:id="@id/mainviewcardview"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardElevation="0.0dip"
        app:cardUseCompatPadding="false"
        app:strokeWidth="0.0dip">
        <FrameLayout
            android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            <LinearLayout
                android:orientation="vertical"
                android:clipToPadding="false"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20.0dip"
                    app:cardUseCompatPadding="true">
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:id="@id/installinstanceslayout"
                        android:padding="12.0dip"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="0.0dip"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.0">
                            <TextView
                                android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                                android:textStyle="bold"
                                android:layout_width="fill_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/instance_list_title" />
                            <TextView
                                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                android:id="@id/textVersionCount"
                                android:layout_width="fill_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2.0dip"
                                android:text="@string/instance_count_value_default" />
                        </LinearLayout>
                        <com.google.android.material.button.MaterialButton
                            android:id="@id/buttonRefreshVersions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minHeight="40.0dip"
                            android:text="@string/button_refresh_versions"
                            android:layout_marginStart="10.0dip"
                            style="@style/Widget.Material3.Button.OutlinedButton" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
                <com.google.android.material.tabs.TabLayout
                    android:id="@id/tabVersionTypes"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8.0dip"
                    app:tabMode="scrollable" />
                <ProgressBar
                    android:id="@id/progressVersions"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6.0dip"
                    android:indeterminate="true"
                    style="?android:progressBarStyleHorizontal" />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@id/recyclerVersions"
                    android:paddingTop="2.0dip"
                    android:paddingBottom="12.0dip"
                    android:clipToPadding="false"
                    android:layout_width="fill_parent"
                    android:layout_height="0.0dip"
                    android:layout_marginTop="8.0dip"
                    android:layout_marginBottom="8.0dip"
                    android:layout_weight="1.0"
                    android:overScrollMode="ifContentScrolls"
                    android:paddingStart="2.0dip"
                    android:paddingEnd="2.0dip"
                    android:nestedScrollingEnabled="true" />
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20.0dip"
                    app:cardUseCompatPadding="true">
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:id="@id/bottomMainActions"
                        android:padding="12.0dip"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content">
                        <com.google.android.material.button.MaterialButton
                            android:id="@id/buttonShareLatestLog"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minHeight="44.0dip"
                            android:text="@string/button_share_latest_log"
                            style="@style/Widget.Material3.Button.OutlinedButton" />
                        <Space
                            android:layout_width="8.0dip"
                            android:layout_height="wrap_content" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@id/buttonOpenSettings"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minHeight="44.0dip"
                            android:text="@string/button_settings"
                            app:icon="@drawable/ic_settings_24"
                            app:iconGravity="textStart"
                            style="@style/Widget.Material3.Button.OutlinedButton" />
                        <TextView
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:ellipsize="end"
                            android:id="@id/textStatus"
                            android:layout_width="0.0dip"
                            android:layout_height="wrap_content"
                            android:text="@string/main_status_ready"
                            android:maxLines="1"
                            android:layout_weight="1.0"
                            android:layout_marginStart="12.0dip"
                            android:layout_marginEnd="92.0dip" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:layout_gravity="end|bottom|center"
                android:id="@id/fabCreateInstance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="22.0dip"
                android:contentDescription="@string/create_instance_button"
                app:srcCompat="@drawable/ic_add_24" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>
    <LinearLayout
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip">
        <TextView
            android:id="@id/textSelectedVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/selected_instance_empty" />
        <com.google.android.material.button.MaterialButton
            android:id="@id/buttonLaunchVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/button_launch_version" />
        <com.google.android.material.button.MaterialButton
            android:id="@id/buttonOpenFolder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/button_open_folder" />
        <TextView
            android:id="@id/textAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name" />
        <TextView
            android:id="@id/textAccountStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_signed_out" />
        <com.google.android.material.button.MaterialButton
            android:id="@id/buttonSignIn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/button_sign_in" />
        <com.google.android.material.button.MaterialButton
            android:id="@id/buttonSignOut"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/button_sign_out" />
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@id/switchShowSharedInstalls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <TextView
            android:id="@id/textSharedInstallsSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <TextView
            android:id="@id/textFolder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <TextView
            android:id="@id/textRenderSurfaceTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@id/switchUseNativeSurface"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <TextView
            android:id="@id/textRenderSurfaceSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <CheckBox
            android:id="@id/checkKeepLogs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>
</FrameLayout>