<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    android:background="?android:colorBackground"
    android:padding="12.0dip"
    android:clipToPadding="false"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:paddingBottom="18.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="14.0dip"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@id/imageProjectDetailsIcon"
                android:background="@drawable/bg_content_project_icon"
                android:padding="10.0dip"
                android:layout_width="78.0dip"
                android:layout_height="78.0dip"
                android:src="@drawable/ic_content_mod_24"
                android:scaleType="centerInside"
                android:contentDescription="@string/content_browser_project_icon_description" />
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0"
                android:layout_marginStart="14.0dip">
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:id="@id/textProjectDetailsTitle"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="2" />
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:ellipsize="end"
                    android:id="@id/textProjectDetailsMeta"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4.0dip"
                    android:maxLines="1" />
            </LinearLayout>
            <com.google.android.material.button.MaterialButton
                android:id="@id/buttonProjectDetailsBack"
                android:layout_width="wrap_content"
                android:layout_height="44.0dip"
                android:minWidth="0.0dip"
                android:minHeight="44.0dip"
                android:text="@string/content_browser_back_to_instance"
                app:icon="@drawable/ic_arrow_back_24"
                style="@style/Widget.Material3.Button.OutlinedButton" />
        </LinearLayout>
        <com.google.android.material.card.MaterialCardView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?colorSurface"
            app:cardCornerRadius="18.0dip"
            app:cardElevation="0.0dip"
            app:strokeColor="?colorOutlineVariant"
            app:strokeWidth="1.0dip">
            <LinearLayout
                android:orientation="vertical"
                android:padding="18.0dip"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                    android:textStyle="bold"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/content_project_details_description_title" />
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                    android:id="@id/textProjectDetailsDescription"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10.0dip" />
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:id="@id/textProjectDetailsGallery"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12.0dip" />
                <com.google.android.material.button.MaterialButton
                    android:id="@id/buttonOpenProjectWebsite"
                    android:layout_width="wrap_content"
                    android:layout_height="44.0dip"
                    android:layout_marginTop="14.0dip"
                    android:minWidth="0.0dip"
                    android:minHeight="44.0dip"
                    android:text="@string/content_browser_open_website"
                    app:icon="@drawable/ic_open_in_new_24"
                    style="@style/Widget.Material3.Button.OutlinedButton" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <TextView
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:id="@id/textProjectDetailsStatus"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14.0dip" />
        <androidx.recyclerview.widget.RecyclerView
            android:id="@id/recyclerProjectVersions"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10.0dip"
            android:nestedScrollingEnabled="false" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>