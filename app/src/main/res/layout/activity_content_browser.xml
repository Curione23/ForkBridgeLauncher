<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    android:id="@id/scrollContentBrowserRoot"
    android:background="?android:colorBackground"
    android:padding="10.0dip"
    android:focusableInTouchMode="true"
    android:clipToPadding="false"
    android:descendantFocusability="beforeDescendants"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:fillViewport="false"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:paddingBottom="18.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@id/layoutContentBrowserHeader"
            android:paddingTop="6.0dip"
            android:paddingBottom="14.0dip"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_gravity="fill"
                android:id="@id/imageContentBrowserInstanceIcon"
                android:background="@drawable/bg_content_browser_instance_icon"
                android:padding="4.0dip"
                android:layout_width="78.0dip"
                android:layout_height="78.0dip"
                android:src="@mipmap/ic_launcher"
                android:scaleType="centerCrop"
                android:contentDescription="@string/content_browser_instance_icon_description" />
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0"
                android:layout_marginStart="14.0dip">
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:id="@id/textContentBrowserInstanceName"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="1" />
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:ellipsize="end"
                    android:id="@id/textContentBrowserInstanceMeta"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4.0dip"
                    android:maxLines="1" />
            </LinearLayout>
            <com.google.android.material.button.MaterialButton
                android:id="@id/buttonBackToInstance"
                android:layout_width="wrap_content"
                android:layout_height="44.0dip"
                android:minWidth="0.0dip"
                android:minHeight="44.0dip"
                android:text="@string/content_browser_back_to_instance"
                android:paddingStart="14.0dip"
                android:paddingEnd="16.0dip"
                android:layout_marginStart="12.0dip"
                app:icon="@drawable/ic_arrow_back_24"
                style="@style/Widget.Material3.Button.OutlinedButton" />
        </LinearLayout>
        <View
            android:background="?colorOutlineVariant"
            android:layout_width="fill_parent"
            android:layout_height="1.0dip" />
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18.0dip">
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                android:textStyle="bold"
                android:id="@id/textContentBrowserTitle"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:text="@string/content_browser_install_title"
                android:layout_weight="1.0" />
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@id/toggleContentSource"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:selectionRequired="true"
                app:singleSelection="true">
                <com.google.android.material.button.MaterialButton
                    android:id="@id/buttonSourceModrinth"
                    android:layout_width="wrap_content"
                    android:layout_height="42.0dip"
                    android:minWidth="0.0dip"
                    android:minHeight="42.0dip"
                    android:text="@string/content_browser_source_modrinth"
                    android:paddingStart="14.0dip"
                    android:paddingEnd="14.0dip"
                    style="@style/Widget.Material3.Button.OutlinedButton" />
                <com.google.android.material.button.MaterialButton
                    android:id="@id/buttonSourceCurseForge"
                    android:layout_width="wrap_content"
                    android:layout_height="42.0dip"
                    android:minWidth="0.0dip"
                    android:minHeight="42.0dip"
                    android:text="@string/content_browser_source_curseforge"
                    android:paddingStart="14.0dip"
                    android:paddingEnd="14.0dip"
                    style="@style/Widget.Material3.Button.OutlinedButton" />
            </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>
        <HorizontalScrollView
            android:scrollbars="none"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16.0dip">
            <FrameLayout
                android:background="@drawable/bg_content_browser_tabs_container"
                android:padding="4.0dip"
                android:layout_width="wrap_content"
                android:layout_height="52.0dip"
                android:clipToOutline="true">
                <com.google.android.material.tabs.TabLayout
                    android:id="@id/tabContentTypes"
                    android:background="@android:color/transparent"
                    android:layout_width="wrap_content"
                    android:layout_height="44.0dip"
                    app:tabGravity="start"
                    app:tabIndicator="@drawable/bg_content_browser_tab_indicator"
                    app:tabIndicatorFullWidth="true"
                    app:tabIndicatorHeight="44.0dip"
                    app:tabMinWidth="0.0dip"
                    app:tabMode="scrollable"
                    app:tabPaddingEnd="18.0dip"
                    app:tabPaddingStart="18.0dip"
                    app:tabRippleColor="@android:color/transparent"
                    app:tabSelectedTextColor="?colorOnPrimaryContainer"
                    app:tabTextAppearance="@style/TextAppearance.Material3.TitleSmall"
                    app:tabTextColor="?colorOnSurfaceVariant" />
            </FrameLayout>
        </HorizontalScrollView>
        <com.google.android.material.textfield.TextInputLayout
            android:id="@id/layoutContentSearch"
            android:background="@drawable/bg_content_browser_search"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16.0dip"
            app:boxBackgroundMode="none"
            app:hintEnabled="false"
            app:startIconDrawable="@drawable/ic_search_24">
            <com.google.android.material.textfield.TextInputEditText
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:id="@id/editContentSearch"
                android:background="@android:color/transparent"
                android:paddingTop="0.0dip"
                android:paddingBottom="0.0dip"
                android:layout_width="fill_parent"
                android:layout_height="48.0dip"
                android:maxLines="1"
                android:singleLine="true"
                android:inputType="text"
                android:imeOptions="actionSearch" />
        </com.google.android.material.textfield.TextInputLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14.0dip">
            <com.google.android.material.button.MaterialButton
                android:id="@id/buttonSortContent"
                android:layout_width="wrap_content"
                android:layout_height="46.0dip"
                android:minWidth="0.0dip"
                android:minHeight="46.0dip"
                android:text="@string/content_browser_sort_downloads"
                android:paddingStart="16.0dip"
                android:paddingEnd="16.0dip"
                app:icon="@drawable/ic_expand_more_24"
                app:iconGravity="textEnd"
                style="@style/Widget.Material3.Button.OutlinedButton" />
            <com.google.android.material.button.MaterialButton
                android:id="@id/buttonViewCount"
                android:layout_width="wrap_content"
                android:layout_height="46.0dip"
                android:minWidth="0.0dip"
                android:minHeight="46.0dip"
                android:text="@string/content_browser_view_count"
                android:paddingStart="16.0dip"
                android:paddingEnd="16.0dip"
                android:layout_marginStart="10.0dip"
                app:icon="@drawable/ic_expand_more_24"
                app:iconGravity="textEnd"
                style="@style/Widget.Material3.Button.OutlinedButton" />
            <Space
                android:layout_width="0.0dip"
                android:layout_height="1.0dip"
                android:layout_weight="1.0" />
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:ellipsize="end"
                android:id="@id/textContentBrowserResultSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:layout_marginStart="8.0dip" />
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12.0dip">
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:id="@id/textContentBrowserVersionChip"
                android:background="@drawable/bg_content_browser_chip"
                android:paddingTop="5.0dip"
                android:paddingBottom="5.0dip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10.0dip"
                android:paddingEnd="10.0dip" />
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:id="@id/textContentBrowserLoaderChip"
                android:background="@drawable/bg_content_browser_chip"
                android:paddingTop="5.0dip"
                android:paddingBottom="5.0dip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10.0dip"
                android:paddingEnd="10.0dip"
                android:layout_marginStart="8.0dip" />
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@id/recyclerContentProjects"
            android:paddingBottom="8.0dip"
            android:focusable="false"
            android:clipToPadding="false"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14.0dip"
            android:nestedScrollingEnabled="false" />
        <LinearLayout
            android:gravity="end|center"
            android:orientation="horizontal"
            android:id="@id/layoutContentPagination"
            android:paddingBottom="8.0dip"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8.0dip">
            <com.google.android.material.button.MaterialButton
                android:id="@id/buttonPagePrevious"
                android:padding="0.0dip"
                android:focusable="false"
                android:layout_width="48.0dip"
                android:layout_height="44.0dip"
                android:minWidth="48.0dip"
                android:minHeight="44.0dip"
                android:contentDescription="@string/content_browser_previous_page"
                app:icon="@drawable/ic_chevron_left_24"
                app:iconGravity="textStart"
                app:iconPadding="0.0dip"
                style="@style/Widget.Material3.Button.OutlinedButton" />
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textStyle="bold"
                android:id="@id/textPageIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14.0dip"
                android:layout_marginEnd="14.0dip" />
            <com.google.android.material.button.MaterialButton
                android:id="@id/buttonPageNext"
                android:padding="0.0dip"
                android:focusable="false"
                android:layout_width="48.0dip"
                android:layout_height="44.0dip"
                android:minWidth="48.0dip"
                android:minHeight="44.0dip"
                android:contentDescription="@string/content_browser_next_page"
                app:icon="@drawable/ic_chevron_right_24"
                app:iconGravity="textStart"
                app:iconPadding="0.0dip"
                style="@style/Widget.Material3.Button.OutlinedButton" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>