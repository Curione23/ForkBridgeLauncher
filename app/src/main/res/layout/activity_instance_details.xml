<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:background="?android:colorBackground"
    android:paddingTop="10.0dip"
    android:paddingBottom="10.0dip"
    android:clipToPadding="false"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:paddingStart="14.0dip"
    android:paddingEnd="14.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.google.android.material.card.MaterialCardView
        android:id="@id/cardInstanceHeader"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="22.0dip"
        app:cardUseCompatPadding="true">
        <LinearLayout
            android:orientation="vertical"
            android:padding="12.0dip"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <com.google.android.material.button.MaterialButton
                    android:id="@id/buttonBackFromInstanceDetails"
                    android:padding="0.0dip"
                    android:layout_width="48.0dip"
                    android:layout_height="48.0dip"
                    android:minWidth="48.0dip"
                    android:minHeight="48.0dip"
                    android:contentDescription="@android:string/cancel"
                    app:icon="@drawable/ic_arrow_back_24"
                    app:iconGravity="textStart"
                    app:iconPadding="0.0dip"
                    style="@style/Widget.Material3.Button.TextButton.Icon" />
                <ImageView
                    android:id="@id/imageInstanceIcon"
                    android:background="@drawable/bg_instance_icon"
                    android:padding="8.0dip"
                    android:layout_width="64.0dip"
                    android:layout_height="64.0dip"
                    android:src="@mipmap/ic_launcher"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/create_instance_select_icon"
                    android:layout_marginStart="8.0dip" />
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:layout_marginStart="14.0dip">
                    <TextView
                        android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                        android:textStyle="bold"
                        android:ellipsize="end"
                        android:id="@id/textInstanceName"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:maxLines="2" />
                    <TextView
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:ellipsize="end"
                        android:id="@id/textInstanceMeta"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3.0dip"
                        android:maxLines="1" />
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:gravity="end|center"
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10.0dip">
                <com.google.android.material.button.MaterialButton
                    android:id="@id/buttonPlay"
                    android:layout_width="0.0dip"
                    android:layout_height="48.0dip"
                    android:minWidth="0.0dip"
                    android:minHeight="48.0dip"
                    android:text="@string/button_play_instance"
                    android:layout_weight="1.0"
                    android:paddingStart="18.0dip"
                    android:paddingEnd="18.0dip" />
                <com.google.android.material.button.MaterialButton
                    android:id="@id/buttonInstanceSettings"
                    android:padding="0.0dip"
                    android:layout_width="48.0dip"
                    android:layout_height="48.0dip"
                    android:minWidth="48.0dip"
                    android:minHeight="48.0dip"
                    android:contentDescription="@string/instance_settings_content_description"
                    android:layout_marginStart="8.0dip"
                    app:icon="@drawable/ic_settings_24"
                    app:iconGravity="textStart"
                    app:iconPadding="0.0dip"
                    style="@style/Widget.Material3.Button.OutlinedButton" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6.0dip">
        <TextView
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textStyle="bold"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:text="@string/instance_details_content_title"
            android:layout_weight="1.0"
            android:layout_marginStart="4.0dip" />
        <HorizontalScrollView
            android:scrollbars="none"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <com.google.android.material.button.MaterialButton
                    android:id="@id/buttonBrowseContent"
                    android:layout_width="wrap_content"
                    android:layout_height="42.0dip"
                    android:minWidth="0.0dip"
                    android:minHeight="42.0dip"
                    android:text="@string/button_browse_content"
                    android:paddingStart="14.0dip"
                    android:paddingEnd="16.0dip"
                    app:icon="@drawable/ic_browse_content_24" />
                <com.google.android.material.button.MaterialButton
                    android:id="@id/buttonAddMods"
                    android:layout_width="wrap_content"
                    android:layout_height="42.0dip"
                    android:minWidth="0.0dip"
                    android:minHeight="42.0dip"
                    android:text="@string/button_upload_mods"
                    android:paddingStart="14.0dip"
                    android:paddingEnd="16.0dip"
                    android:layout_marginStart="8.0dip"
                    style="@style/Widget.Material3.Button.OutlinedButton" />
                <com.google.android.material.button.MaterialButton
                    android:id="@id/buttonCheckContentUpdates"
                    android:layout_width="wrap_content"
                    android:layout_height="42.0dip"
                    android:minWidth="0.0dip"
                    android:minHeight="42.0dip"
                    android:text="@string/instance_content_check_updates"
                    android:paddingStart="14.0dip"
                    android:paddingEnd="16.0dip"
                    android:layout_marginStart="8.0dip"
                    app:icon="@drawable/ic_sync_24"
                    style="@style/Widget.Material3.Button.OutlinedButton" />
                <com.google.android.material.button.MaterialButton
                    android:id="@id/buttonUpdateAllContent"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="42.0dip"
                    android:minWidth="0.0dip"
                    android:minHeight="42.0dip"
                    android:text="@string/instance_content_update_all"
                    android:paddingStart="14.0dip"
                    android:paddingEnd="16.0dip"
                    android:layout_marginStart="8.0dip"
                    app:icon="@drawable/ic_update_24" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>
    <TextView
        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
        android:id="@id/textModsHint"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2.0dip"
        android:layout_marginStart="4.0dip" />
    <com.google.android.material.textfield.TextInputLayout
        android:id="@id/layoutContentSearch"
        android:layout_width="fill_parent"
        android:layout_height="48.0dip"
        android:layout_marginTop="6.0dip"
        app:boxCornerRadiusBottomEnd="18.0dip"
        app:boxCornerRadiusBottomStart="18.0dip"
        app:boxCornerRadiusTopEnd="18.0dip"
        app:boxCornerRadiusTopStart="18.0dip"
        app:boxStrokeWidth="1.0dip"
        app:boxStrokeWidthFocused="2.0dip"
        app:endIconMode="clear_text"
        app:hintEnabled="false"
        app:startIconDrawable="@drawable/ic_search_24"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@id/editTextContentSearch"
            android:background="@android:color/transparent"
            android:paddingTop="0.0dip"
            android:paddingBottom="0.0dip"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:hint="Search content"
            android:maxLines="1"
            android:singleLine="true"
            android:inputType="text"
            android:imeOptions="actionDone|flagNoExtractUi" />
    </com.google.android.material.textfield.TextInputLayout>
    <HorizontalScrollView
        android:scrollbars="none"
        android:clipToPadding="false"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8.0dip"
        android:fillViewport="false"
        android:overScrollMode="never">
        <ca.dnamobile.javalauncher.ui.view.RoundedClipFrameLayout
            android:id="@id/layoutResourceCategoryTabs"
            android:background="@drawable/bg_content_tab_container"
            android:clipChildren="true"
            android:clipToPadding="true"
            android:layout_width="wrap_content"
            android:layout_height="52.0dip"
            android:minHeight="52.0dip">
            <com.google.android.material.tabs.TabLayout
                android:id="@id/tabResourceCategories"
                android:background="@android:color/transparent"
                android:padding="4.0dip"
                android:layout_width="wrap_content"
                android:layout_height="52.0dip"
                app:tabGravity="start"
                app:tabIndicator="@drawable/bg_content_tab_indicator"
                app:tabIndicatorFullWidth="true"
                app:tabIndicatorHeight="44.0dip"
                app:tabMinWidth="0.0dip"
                app:tabMode="scrollable"
                app:tabPaddingEnd="18.0dip"
                app:tabPaddingStart="18.0dip"
                app:tabRippleColor="@android:color/transparent"
                app:tabSelectedTextColor="?colorOnPrimaryContainer"
                app:tabTextAppearance="@style/TextAppearance.Material3.TitleSmall"
                app:tabTextColor="?colorOnSurfaceVariant" />
        </ca.dnamobile.javalauncher.ui.view.RoundedClipFrameLayout>
    </HorizontalScrollView>
    <com.google.android.material.card.MaterialCardView
        android:id="@id/cardResourceItems"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:layout_marginTop="8.0dip"
        android:layout_weight="1.0"
        app:cardCornerRadius="20.0dip"
        app:cardUseCompatPadding="true">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@id/recyclerResourceItems"
            android:padding="8.0dip"
            android:clipToPadding="false"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:overScrollMode="ifContentScrolls"
            android:nestedScrollingEnabled="true" />
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>